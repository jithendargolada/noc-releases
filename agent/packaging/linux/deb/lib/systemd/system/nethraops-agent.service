[Unit]
Description=NethraOps Agent (DEB/RPM packaging, Phase 1C)
Documentation=https://github.com/jithendargolada/mysysteminfo/tree/main/agent
After=network-online.target
Wants=network-online.target

# This unit ships with the nethraops-agent DEB/RPM. It runs in
# parallel with the legacy nethraops-agent.service shipped by the
# one-line install.sh flow. Operators should pick one - both writing
# to the same /var/lib/nethraops-agent will collide on buffer.sqlite.

[Service]
Type=simple
User=nethraops-agent
Group=nethraops-agent
WorkingDirectory=/var/lib/nethraops-agent
ExecStart=/opt/nethraops-agent/venv/bin/nethraops-agent run
EnvironmentFile=-/etc/nethraops-agent/agent.env

# Restart policy: always restart, but rate-limit to 5 starts in 5
# minutes so a fatal crash loop does not flood journald.
Restart=always
RestartSec=10s
StartLimitBurst=5
StartLimitIntervalSec=300
TimeoutStartSec=30s
TimeoutStopSec=15s

# Hardening - same surface as the legacy unit, slightly tighter on
# address families (only what httpx + psutil actually need).
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=no
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallArchitectures=native
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

# Buffer + state + logs + (read-only) config live here.
ReadWritePaths=/var/lib/nethraops-agent /var/log/nethraops-agent

# psutil reads /proc and /sys without any extra capabilities; we drop
# the full bounding set explicitly. CAP_SYS_RAWIO would be required
# if SMART/kernel-module probes are enabled later (out of Phase 1C).
CapabilityBoundingSet=
AmbientCapabilities=

# Logs to journald: journalctl -u nethraops-agent
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
# systemctl preset rules in /usr/lib/systemd/system-preset/ override
# the default. To pin "enabled" on first install across distros, ship
# an /lib/systemd/system-preset/50-nethraops-agent.preset file
# with: enable nethraops-agent.service
