# NethraOps agent pre-seeded install configuration.
#
# Rename this file to /etc/nethraops-agent/install.conf BEFORE running
# `apt install nethraops-agent` (or place it via cloud-init /
# Ansible / Puppet so it lands before the postinst hook runs).
#
# Format: KEY=VALUE per line. No quoting, no spaces around '='.
#
# Supported keys:
#   CLAIM_TOKEN    One-shot enrolment token issued by the platform.
#   PLATFORM_URL   Base URL of the NethraOps platform (https://...).
#   DEVICE_GROUP   Optional device group slug (e.g. prod-east).
#   HOST_LABEL     Optional human-readable host label.
#
# The postinst hook redeems the claim via:
#   curl -fsSL "${PLATFORM_URL}/install/linux.sh?claim=${CLAIM_TOKEN}" | bash
# - exactly the same flow as the Phase 1A one-line installer.

CLAIM_TOKEN=
PLATFORM_URL=https://monitor.example.com
DEVICE_GROUP=
HOST_LABEL=
