[Unit]
Description=NethraOps Agent
Documentation=https://github.com/jithendargolada/mysysteminfo/tree/main/agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nethraops-agent
Group=nethraops-agent
ExecStart=/opt/nethraops-agent/venv/bin/nethraops-agent run
EnvironmentFile=-/etc/nethraops-agent/agent.env
Restart=on-failure
RestartSec=5s
TimeoutStartSec=30s
TimeoutStopSec=15s

# Hardening — drop privileges + filesystem access we don't need.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=no
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallArchitectures=native

# We need write access to the buffer + state files.
ReadWritePaths=/var/lib/nethraops-agent

# Capabilities: psutil reads /proc and /sys; no special caps required
# in the default config. If you turn on disk SMART or kernel-module
# probes (out of Phase 2B-6 scope) you'll need CAP_SYS_RAWIO here.
CapabilityBoundingSet=
AmbientCapabilities=

# Logs go to journald — `journalctl -u nethraops-agent`.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
